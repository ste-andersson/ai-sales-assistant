<configuration>
    <appender name="TIME_FILE" class="ch.qos.logback.core.FileAppender">
        <file>logs/performance.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} - %msg%n</pattern>
        </encoder>
    </appender>

    <logger name="PerformanceLogger" level="INFO" additivity="false">
        <appender-ref ref="TIME_FILE" />
    </logger>

    <root level="OFF">
    </root>
</configuration>